    %% User → Proxy connections
    NEWELLE -->|"MCP tools"| MCP
    NEWELLE -->|"LLM chat"| PROXY
    CLAUDECODE -->|"LLM chat"| PROXY
    TRAY -->|"reads .status"| SECDIR

    %% Proxy → Core (IMPORTANT: MCP does NOT connect to ROUTER)
    PROXY --> ROUTER
    ROUTER --> HEALTH

    %% MCP dispatches to subsystems (NOT to router)
    MCP --> RAG
    MCP --> INTEL
    MCP --> LOGINTEL
    MCP --> AGENTS
    MCP --> SYSMOD
    MCP --> GAMING
    MCP --> HEALTH_MON
    MCP --> CLAMAV

    %% Router → Providers
    ROUTER --> RATELIMIT
    ROUTER --> GEMINI
    ROUTER --> GROQ
    ROUTER --> MISTRAL
    ROUTER --> OPENROUTER
    ROUTER --> ZAI
    ROUTER --> CEREBRAS
    ROUTER --> DISKCACHE

    %% RAG connections
    RAG --> LANCEDB
    RAG -->|"embed (primary)"| GEMINI
    RAG -->|"embed (emergency)"| OLLAMA

    %% Threat intel
    INTEL --> VT
    INTEL --> OTX
    INTEL --> MALWAREBAZAAR
    INTEL --> ABUSEIPDB
    INTEL --> GREYNOISE
    INTEL --> SHODAN
    INTEL --> NVD
    INTEL --> URLHAUS
    INTEL --> HYBRID

    %% Log intel
    LOGINTEL --> LANCEDB
    LOGINTEL --> SECDIR

    %% Agents orchestrate subsystems
    AGENTS --> RAG
    AGENTS --> INTEL
    AGENTS --> LOGINTEL

    %% System writes
    CLAMAV --> SECDIR
    HEALTH_MON --> SECDIR

    %% Systemd triggers
    SYSTEMD -.->|triggers| CLAMAV
    SYSTEMD -.->|triggers| HEALTH_MON
    SYSTEMD -.->|triggers| RAG
    SYSTEMD -.->|triggers| AGENTS
    SYSTEMD -.->|triggers| SYSMOD

    %% OpenCode goes direct to z.ai (NOT through local proxy)
    OPENCODE -->|"direct API"| ZAI

