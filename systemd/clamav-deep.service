# ClamAV weekly deep scan service
# Deploy to: /etc/systemd/system/clamav-deep.service

[Unit]
Description=ClamAV deep scan (home + tmp + var + Steam library)

[Service]
Type=oneshot
ExecStart=/usr/local/bin/clamav-scan.sh deep
Nice=15
IOSchedulingClass=idle
MemoryMax=2G
CPUQuota=50%

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ReadWritePaths=/var/log/clamav-scans /home/lch/security
