# WIP — DO NOT ENABLE
# This service uses a plain JSON-RPC HTTP endpoint, but Newelle requires the
# MCP streamable-http protocol. The proxy must be updated before this can be
# deployed. See ai/mcp_bridge/claude_flow_proxy.py for implementation details.
# deploy-services.sh intentionally skips this service until it is ready.

[Unit]
Description=Claude-Flow MCP stdio-to-HTTP Proxy for Newelle (WIP — disabled)
After=network.target claude-flow.service

[Service]
Type=simple
WorkingDirectory=/var/home/lch/projects/bazzite-laptop
Environment=PATH=/var/home/lch/projects/bazzite-laptop/.venv/bin:/var/home/lch/projects/bazzite-laptop/node_modules/.bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/var/home/lch/projects/bazzite-laptop/.venv/bin/python -m ai.mcp_bridge.claude_flow_proxy --bind 127.0.0.1 --port 8768
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
ReadWritePaths=/var/home/lch/projects/bazzite-laptop

[Install]
WantedBy=default.target
