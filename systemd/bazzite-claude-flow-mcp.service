[Unit]
Description=Claude-Flow MCP stdio-to-HTTP Proxy for Newelle
After=network.target claude-flow.service

[Service]
Type=simple
WorkingDirectory=/var/home/lch/projects/bazzite-laptop
Environment=PATH=/var/home/lch/projects/bazzite-laptop/.venv/bin:/var/home/lch/projects/bazzite-laptop/node_modules/.bin:/usr/bin:/bin
ExecStart=/var/home/lch/projects/bazzite-laptop/.venv/bin/python -m ai.mcp_bridge.claude_flow_proxy --bind 127.0.0.1 --port 8768
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
ProtectSystem=strict
PrivateTmp=yes
ReadWritePaths=/var/home/lch/projects/bazzite-laptop

[Install]
WantedBy=default.target
