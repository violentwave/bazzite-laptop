# ClamAV daily quick scan service
# Deploy to: /etc/systemd/system/clamav-quick.service

[Unit]
Description=ClamAV quick scan (home + tmp)

[Service]
Type=oneshot
ExecStart=/usr/local/bin/clamav-scan.sh quick
Nice=15
IOSchedulingClass=idle
MemoryMax=2G
CPUQuota=50%

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
ReadWritePaths=/var/log/clamav-scans /home/lch/security
