# ClamAV Deep Scan — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-deep-scan.desktop
[Desktop Entry]
Type=Application
Name=ClamAV Deep Scan
Comment=Run a full antivirus scan including Steam library
Exec=konsole -e sudo /usr/local/bin/clamav-scan.sh deep
Icon=security-high
Categories=Security;System;
Terminal=false
