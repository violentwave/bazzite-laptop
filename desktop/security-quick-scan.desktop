# ClamAV Quick Scan — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-quick-scan.desktop
[Desktop Entry]
Type=Application
Name=Quick Scan
Comment=Scan home and tmp directories
Exec=konsole -e bash -c "sudo /usr/local/bin/clamav-scan.sh quick; echo; echo Press Enter to close; read"
Icon=/home/lch/security/icons/hicolor/scalable/status/bazzite-sec-green.svg
Categories=Security;System;
Terminal=false
