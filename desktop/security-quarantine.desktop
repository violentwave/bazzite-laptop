# View Quarantine — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-quarantine.desktop
[Desktop Entry]
Type=Application
Name=View Quarantine
Comment=View quarantined threat files
Exec=dolphin /home/lch/security/quarantine
Icon=/home/lch/security/icons/hicolor/scalable/status/bazzite-sec-red.svg
Categories=Security;System;X-Bazzite-Security;
Terminal=false
