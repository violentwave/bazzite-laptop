# ClamAV Deep Scan — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-deep-scan.desktop
[Desktop Entry]
Type=Application
Name=Deep Scan
Comment=Full scan of home, tmp, and var
Exec=konsole -e bash -c "sudo /usr/local/bin/clamav-scan.sh deep; echo; echo Press Enter to close; read"
Icon=/home/lch/security/icons/hicolor/scalable/status/bazzite-sec-green.svg
Categories=Security;System;X-Bazzite-Security;
Terminal=false
NoDisplay=true
