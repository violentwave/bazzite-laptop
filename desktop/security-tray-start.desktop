# Bazzite Security Tray — KDE menu shortcut to start/restart the tray icon
# Deploy to: ~/.local/share/applications/security-tray-start.desktop
[Desktop Entry]
Type=Application
Name=Start Security Monitor
Comment=Start or restart the security tray monitor
Icon=bazzite-sec-teal
Exec=bash -c 'pkill -f bazzite-security-tray 2>/dev/null; sleep 1; nohup python3 /home/lch/security/bazzite-security-tray.py &>/dev/null & disown'
Terminal=false
Categories=Security;System;
StartupNotify=false
