# ClamAV Health Check — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-healthcheck.desktop
[Desktop Entry]
Type=Application
Name=Run Health Check
Comment=Run ClamAV infrastructure health check
Exec=konsole -e bash -c "sudo /usr/local/bin/clamav-healthcheck.sh; echo; echo Press Enter to close; read"
Icon=/home/lch/security/icons/hicolor/scalable/status/bazzite-sec-blue.svg
Categories=Security;System;X-Bazzite-Security;
Terminal=false
NoDisplay=true
