# USB Devices — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-usb-devices.desktop
[Desktop Entry]
Type=Application
Name=USB Devices
Comment=View and manage USB device authorization
Exec=konsole -e bash -c "usbguard list-devices 2>/dev/null || echo 'USBGuard not running'; echo '---'; lsusb; echo '---'; echo 'Press Enter to close'; read"
Icon=drive-removable-media
Categories=Security;System;X-Bazzite-Security;
Terminal=false
