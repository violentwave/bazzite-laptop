# Scan Logs — KDE menu shortcut
# Deploy to: ~/.local/share/applications/security-scan-logs.desktop
[Desktop Entry]
Type=Application
Name=View Scan Logs
Comment=Open ClamAV scan log directory
Exec=dolphin /home/lch/security/logs
Icon=folder-documents
Categories=Security;System;X-Bazzite-Security;
Terminal=false
