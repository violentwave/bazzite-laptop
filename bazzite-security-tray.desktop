[Desktop Entry]
Type=Application
Name=Bazzite Security Monitor
Comment=System tray security status monitor
Icon=security-high
Exec=python3 /home/lch/security/bazzite-security-tray.py
Terminal=false
Categories=Security;System;
StartupNotify=false
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=5
X-KDE-autostart-after=panel
